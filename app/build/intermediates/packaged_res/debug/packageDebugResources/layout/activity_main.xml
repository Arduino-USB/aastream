<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <Button
        android:id="@+id/btn_toggle_stream"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Screen Capture"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_network_stream"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Network Stream"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_native_video"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Native Video"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:id="@+id/layout_media_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#1AFFFFFF"
        android:padding="16dp">
		
		<LinearLayout
		    android:layout_width="match_parent"
		    android:layout_height="wrap_content"
		    android:orientation="horizontal"
		    android:gravity="center_vertical"
		    android:layout_marginBottom="12dp">
		
		    <TextView
		        android:id="@+id/tv_current_time"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="00:00"
		        android:textColor="#FFFFFF"
		        android:textSize="12sp" />
		
		    <SeekBar
		        android:id="@+id/media_seekbar"
		        android:layout_width="0dp"
		        android:layout_height="wrap_content"
		        android:layout_weight="1"
		        android:max="1000" />
		
		    <TextView
		        android:id="@+id/tv_total_time"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="00:00"
		        android:textColor="#FFFFFF"
		        android:textSize="12sp" />
		</LinearLayout>
			
		
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
			
			
			
            <Button
                android:id="@+id/btn_media_pause"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Pause"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_media_stop"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Stop"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio Track Selection:"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinner_audio_tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subtitle Track Selection:"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinner_subtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"/>
    </LinearLayout>
</LinearLayout>
